{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "YiYi",
  "version": "0.0.1",
  "identifier": "com.yiyi.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "YiYi",
        "width": 1500,
        "height": 1000,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "visible": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "src-python/": "src-python/",
      "wheels/": "wheels/",
      "python-stdlib/": "python-stdlib/",
      "skills/": "skills/"
    },
    "createUpdaterArtifacts": true,
    "macOS": {
      "frameworks": ["libs/libpython3.13.dylib"],
      "signingIdentity": "-",
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 },
        "windowSize": { "width": 660, "height": 400 },
        "background": "icons/dmg-background.png"
      },
      "minimumSystemVersion": "10.15"
    },
    "category": "Productivity",
    "shortDescription": "Your AI companion that grows with you",
    "longDescription": "YiYi is a desktop AI personal assistant that can operate your computer, execute tasks, manage files, and learn from every interaction. She grows smarter the more you use her."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/vibeinging/YiYi/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJERTY5RkE4QkREQTg4MjUKUldRbGlOcTlxSi9tTFY3Y3RFd1VyR3BCWk16TWJkWlJseVhkNVorU2YyN3ZBalpDb3FJeU5JaGoK"
    }
  }
}
