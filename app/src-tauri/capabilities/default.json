{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions granted to the main YiYi window (the primary webview the user interacts with).",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-create",
    "core:webview:allow-create-webview-window",
    "shell:allow-open",
    "shell:allow-execute",
    "notification:default",
    "updater:default",
    "process:allow-restart",
    "process:allow-exit",
    "pty:default"
  ]
}
